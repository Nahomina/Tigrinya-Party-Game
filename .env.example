# Mayim — Supabase Configuration
# Copy this file to .env.local and fill in your actual credentials
# Get these from: https://supabase.com/dashboard → Settings → API

# Your Supabase project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase anonymous/public API key (safe for frontend use)
SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Vercel deployment
# VERCEL_ENV=production
